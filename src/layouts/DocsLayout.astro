---
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { fade } from 'astro:transitions';
import { siteConfig } from '../config/site';
import { getDocPath, sortDocsByOrder } from '../lib/docs';

const docs = await getCollection('docs');
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';

function isActive(path: string): boolean {
  const normalizedPath = path.replace(/\/+$/, '') || '/';
  return currentPath === normalizedPath;
}

// Icon mapping
const icons = {
  book: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
  </svg>`,
  rocket: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
  </svg>`,
  sparkles: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
  </svg>`
};

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// Sort docs by order
const sortedDocs = [...docs].sort(sortDocsByOrder);
---

<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - {siteConfig.name} Documentation</title>
    <meta name="description" content={description} />
  </head>
  <body class="hig-shell h-full bg-gray-50">
    <div class="flex min-h-full">
      <!-- Sidebar -->
      <aside class="fixed inset-y-0 left-0 hidden w-72 overflow-y-auto border-r border-gray-200 bg-white px-4 py-6 sm:px-6 lg:px-8 xl:block">
        <nav class="space-y-1">
          <div class="mb-8">
            <a href="/docs/introduction" class="flex items-center">
              <svg class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="ml-2 text-xl font-semibold text-gray-900">Docs</span>
            </a>
          </div>
          
          {sortedDocs.map((doc) => (
            <a
              href={getDocPath(doc)}
              class:list={[
                'js-doc-nav-item flex items-center px-3 py-2.5 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out gap-x-3 group hover:bg-blue-50/50 relative',
                isActive(getDocPath(doc))
                  ? 'bg-blue-50 text-blue-700 shadow-sm before:absolute before:left-0 before:top-1/2 before:-translate-y-1/2 before:h-8 before:w-0.5 before:bg-blue-500 before:rounded-full'
                  : 'text-gray-700 hover:text-blue-600'
              ]}
            >
              <span 
                class:list={[
                  'flex-shrink-0 transition-all duration-200 ease-in-out transform group-hover:scale-110',
                  isActive(getDocPath(doc))
                    ? 'text-blue-600' 
                    : 'text-gray-400 group-hover:text-blue-500'
                ]}
              >
                <Fragment set:html={icons[doc.data.icon] || icons.book} />
              </span>
              <span class="truncate">{doc.data.title}</span>
            </a>
          ))}
        </nav>
      </aside>

      <!-- Main content -->
      <main class="flex-1 xl:pl-72 xl:pr-64">
        <!-- Top navigation -->
        <nav class="js-doc-topbar fixed top-0 left-0 right-0 z-40 flex h-16 items-center justify-between bg-white/85 px-4 backdrop-blur-lg sm:px-6 xl:left-72 xl:right-64 xl:px-8 border-b border-gray-200/60">
          <div class="flex flex-1 items-center">
            <!-- Mobile navigation is intentionally simple and dependency-free. -->
            <details class="relative xl:hidden">
              <summary class="list-none cursor-pointer rounded-lg p-1 text-gray-500 hover:bg-gray-100 hover:text-gray-700">
                <span class="sr-only">Open sidebar</span>
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
              </summary>
              <div class="absolute left-0 top-10 w-[min(20rem,calc(100vw-2rem))] rounded-xl border border-gray-200 bg-white p-3 shadow-xl">
                <nav class="space-y-1">
                  {sortedDocs.map((doc) => (
                    <a
                      href={getDocPath(doc)}
                      class:list={[
                        'flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-200',
                        isActive(getDocPath(doc)) ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-blue-50/60 hover:text-blue-600'
                      ]}
                    >
                      <span class="flex-shrink-0 text-gray-400">
                        <Fragment set:html={icons[doc.data.icon] || icons.book} />
                      </span>
                      <span class="truncate">{doc.data.title}</span>
                    </a>
                  ))}
                </nav>
              </div>
            </details>
            <div class="ml-4 flex-1">
              <div class="relative group">
                <input
                  id="docs-search-input"
                  type="search"
                  placeholder="Quick search..."
                  autocomplete="off"
                  class="hig-input block w-full py-2 pl-10 pr-3 text-sm placeholder-gray-500 
                  transition-all duration-200
                  group-hover:border-gray-300 group-hover:bg-white"
                />
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                  <svg class="h-5 w-5 text-gray-400 transition-colors duration-200 group-hover:text-gray-500" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div
                  id="docs-search-results"
                  class="absolute left-0 right-0 top-12 z-50 hidden max-h-80 overflow-y-auto rounded-xl border border-gray-200 bg-white p-2 shadow-xl"
                ></div>
              </div>
            </div>
          </div>
        </nav>

        <!-- Content -->
        <div class="px-4 pt-24 pb-16 sm:px-6 xl:px-8">
          <div class="js-doc-shell mx-auto w-full max-w-5xl rounded-3xl border border-gray-200/80 bg-white p-6 shadow-sm sm:p-8 lg:p-10">
            <article 
              id="docs-article"
              class="prose prose-apple docs-prose max-w-none"
              transition:animate={fade({ duration: '0.3s' })}
            >
              <slot />
            </article>
          </div>
        </div>
      </main>

      <!-- Right sidebar -->
      <aside class="fixed inset-y-0 right-0 hidden w-64 overflow-y-auto border-l border-gray-200/90 bg-white/90 px-4 py-6 backdrop-blur xl:block">
        <nav class="space-y-3">
          <h4 class="text-sm font-medium text-gray-900">On this page</h4>
          <div id="toc-nav" class="space-y-2"></div>
        </nav>
      </aside>
    </div>

    <style is:global>
      .prose-apple {
        --tw-prose-body: #374151;
        --tw-prose-headings: #111827;
        --tw-prose-links: #0066cc;
        --tw-prose-bold: #111827;
        --tw-prose-counters: #6b7280;
        --tw-prose-bullets: #d1d5db;
        --tw-prose-hr: #e5e7eb;
        --tw-prose-quotes: #111827;
        --tw-prose-quote-borders: #e5e7eb;
        --tw-prose-captions: #6b7280;
        --tw-prose-code: #111827;
        --tw-prose-pre-code: #e5e7eb;
        --tw-prose-pre-bg: #1f2937;
        --tw-prose-th-borders: #d1d5db;
        --tw-prose-td-borders: #e5e7eb;
      }

      .prose-apple :where(h1, h2, h3, h4, h5, h6):not(:where([class~="not-prose"] *)) {
        font-weight: 600;
        letter-spacing: -0.025em;
        line-height: 1.25;
        margin-top: 2.5em;
        margin-bottom: 1em;
      }

      .prose-apple :where(a):not(:where([class~="not-prose"] *)) {
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s ease;
      }

      .prose-apple :where(a):not(:where([class~="not-prose"] *)):hover {
        color: #004499;
      }

      .prose-apple :where(pre):not(:where([class~="not-prose"] *)) {
        background-color: #f8f9fa;
        border: 1px solid #e5e7eb;
        padding: 1.25em;
        border-radius: 0.75rem;
        overflow-x: auto;
      }

      .prose-apple :where(code):not(:where([class~="not-prose"] *)) {
        font-size: 0.875em;
        font-weight: 500;
        background: rgba(0, 0, 0, 0.05);
        border-radius: 4px;
        padding: 0.2em 0.4em;
        transition: background-color 0.2s ease;
      }

      .prose-apple :where(code):not(:where([class~="not-prose"] *)):hover {
        background: rgba(0, 0, 0, 0.08);
      }

      .prose-apple :where(blockquote):not(:where([class~="not-prose"] *)) {
        font-weight: 400;
        font-style: normal;
        border-left-width: 0.25rem;
        border-left-color: #e5e7eb;
        background-color: #f8f9fa;
        border-radius: 0.5rem;
        padding: 1rem 1.5rem;
        margin: 1.5rem 0;
      }

      .prose-apple :where(ul > li):not(:where([class~="not-prose"] *))::marker {
        color: #d1d5db;
      }

      .prose-apple :where(ol > li):not(:where([class~="not-prose"] *))::marker {
        color: #6b7280;
        font-weight: 400;
      }

      .prose-apple :where(table):not(:where([class~="not-prose"] *)) {
        border-collapse: separate;
        border-spacing: 0;
        border-radius: 0.5rem;
        border: 1px solid #e5e7eb;
        margin-top: 2em;
        margin-bottom: 2em;
        overflow: hidden;
      }

      .prose-apple :where(th):not(:where([class~="not-prose"] *)) {
        background-color: #f8f9fa;
        font-weight: 500;
        text-align: left;
        padding: 0.75em 1em;
      }

      .prose-apple :where(td):not(:where([class~="not-prose"] *)) {
        padding: 0.75em 1em;
        border-top: 1px solid #e5e7eb;
      }

      details[open] > summary {
        margin-bottom: 0;
      }

      summary::-webkit-details-marker {
        display: none;
      }
    </style>

    <script type="module">
      import { gsap } from 'gsap';

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        gsap.from('.js-doc-topbar', {
          y: -12,
          opacity: 0,
          duration: 0.55,
          ease: 'power2.out'
        });

        gsap.from('.js-doc-shell', {
          y: 18,
          opacity: 0,
          duration: 0.65,
          delay: 0.1,
          ease: 'power2.out'
        });

        gsap.from('.js-doc-nav-item', {
          x: -10,
          opacity: 0,
          duration: 0.5,
          stagger: 0.04,
          delay: 0.1,
          ease: 'power2.out'
        });
      }
    </script>

    <script>
      const article = document.getElementById('docs-article');
      const tocNav = document.getElementById('toc-nav');

      if (article && tocNav) {
        const headings = Array.from(article.querySelectorAll('h2, h3'));

        const slugify = (value) =>
          value
            .toLowerCase()
            .trim()
            .replace(/['"]/g, '')
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-');

        const tocItems = headings
          .map((heading, index) => {
            if (!heading.id) {
              heading.id = slugify(heading.textContent || `section-${index + 1}`);
            }

            heading.setAttribute('data-reveal-section', 'true');

            return {
              id: heading.id,
              text: heading.textContent?.trim() || `Section ${index + 1}`,
              level: heading.tagName.toLowerCase(),
            };
          })
          .filter(Boolean);

        if (tocItems.length > 0) {
          tocNav.innerHTML = tocItems
            .map(
              (item) => `
                <a href="#${item.id}" data-toc-link="${item.id}" class="toc-link group flex items-start gap-2 rounded-lg px-2 py-2 text-sm text-gray-600 transition-colors hover:bg-blue-50 hover:text-blue-700">
                  <span class="mt-1 h-1.5 w-1.5 rounded-full bg-gray-300 transition-colors group-hover:bg-blue-500"></span>
                  <span class="leading-5 ${item.level === 'h3' ? 'pl-3 text-[13px]' : 'font-medium'}">${item.text}</span>
                </a>
              `
            )
            .join('');

          const revealTargets = Array.from(article.querySelectorAll('p, ul, ol, pre, blockquote, table, h2, h3, .hig-card'));

          if (!prefersReducedMotion) {
            const io = new IntersectionObserver(
              (entries) => {
                entries.forEach((entry) => {
                  if (entry.isIntersecting) {
                    gsap.to(entry.target, {
                      y: 0,
                      opacity: 1,
                      duration: 0.55,
                      ease: 'power2.out'
                    });
                    io.unobserve(entry.target);
                  }
                });
              },
              { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
            );

            revealTargets.forEach((target) => {
              if (target.tagName?.toLowerCase() === 'h2' || target.tagName?.toLowerCase() === 'h3') {
                target.style.scrollMarginTop = '7rem';
              }

              target.style.opacity = '0';
              target.style.transform = 'translateY(18px)';
              io.observe(target);
            });
          }

          const tocLinks = Array.from(tocNav.querySelectorAll('[data-toc-link]'));
          const headingObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                tocLinks.forEach((link) => {
                  const active = link.getAttribute('data-toc-link') === entry.target.id;
                  link.classList.toggle('bg-blue-50', active);
                  link.classList.toggle('text-blue-700', active);
                  link.classList.toggle('font-semibold', active);
                  link.classList.toggle('shadow-sm', active);
                  link.classList.toggle('border-l-2', active);
                  link.classList.toggle('border-blue-500', active);
                });
              });
            },
            { rootMargin: '-30% 0px -55% 0px', threshold: 0.1 }
          );

          headings.forEach((heading) => headingObserver.observe(heading));
        } else {
          tocNav.innerHTML = '<p class="text-sm text-gray-500">No headings on this page.</p>';
        }
      }
    </script>

    <script>
      // Progressive client search for production builds where Pagefind assets exist.
      const searchInput = document.getElementById('docs-search-input');
      const resultsContainer = document.getElementById('docs-search-results');

      if (searchInput && resultsContainer) {
        let searchApiPromise;
        const loadModule = new Function('path', 'return import(path);');

        async function getSearchApi() {
          if (!searchApiPromise) {
            searchApiPromise = loadModule('/pagefind/pagefind.js')
              // pagefind assets exist after build in dist/pagefind.
              .then((module) => {
                module.options({ excerptLength: 16 });
                return module;
              })
              .catch(() => null);
          }

          return searchApiPromise;
        }

        async function renderResults() {
          const query = searchInput.value.trim();

          if (!query) {
            resultsContainer.classList.add('hidden');
            resultsContainer.innerHTML = '';
            return;
          }

          const pagefind = await getSearchApi();

          if (!pagefind) {
            resultsContainer.classList.remove('hidden');
            resultsContainer.innerHTML = '<p class="px-3 py-2 text-sm text-gray-500">Search index is generated during production build.</p>';
            return;
          }

          const search = await pagefind.search(query);
          const matches = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));

          if (matches.length === 0) {
            resultsContainer.classList.remove('hidden');
            resultsContainer.innerHTML = '<p class="px-3 py-2 text-sm text-gray-500">No matches found.</p>';
            return;
          }

          resultsContainer.classList.remove('hidden');
          resultsContainer.innerHTML = matches
            .map(
              (match) =>
                `<a href="${match.url}" class="block rounded-lg px-3 py-2 hover:bg-blue-50">` +
                `<p class="text-sm font-medium text-gray-900">${match.meta?.title || 'Untitled'}</p>` +
                `<p class="mt-1 text-xs text-gray-600">${match.excerpt || ''}</p>` +
                '</a>'
            )
            .join('');
        }

        let searchDebounceTimer;
        searchInput.addEventListener('input', () => {
          clearTimeout(searchDebounceTimer);
          searchDebounceTimer = setTimeout(renderResults, 120);
        });

        document.addEventListener('click', (event) => {
          if (!resultsContainer.contains(event.target) && event.target !== searchInput) {
            resultsContainer.classList.add('hidden');
          }
        });
      }
    </script>
  </body>
</html>

