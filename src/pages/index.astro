---
import { getCollection } from 'astro:content';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '../styles/global.css';
import { siteConfig } from '../config/site';
import { getDocPath, sortDocsByOrder } from '../lib/docs';
import DocIcon from '../components/DocIcon';
import { ArrowRight, Code2 } from 'lucide-react';

const docs = await getCollection('docs');
const sortedDocs = [...docs].sort(sortDocsByOrder);

// Use the first non-index page as the default call-to-action target.
const firstDocPage = sortedDocs.find((doc) => getDocPath(doc) !== '/docs');
const getStartedPath = firstDocPage ? getDocPath(firstDocPage) : '/docs';

---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteConfig.name} Documentation</title>
    <meta name="description" content={siteConfig.description} />
    <style>
      @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
        100% { transform: translateY(0px); }
      }
      
      .float-animation {
        animation: float 6s ease-in-out infinite;
      }

      .hover-lift {
        transition: transform 0.2s ease-in-out;
      }
      
      .hover-lift:hover {
        transform: translateY(-2px);
      }
    </style>
  </head>
  <body class="hig-shell bg-white min-h-screen">
    <!-- Hero section -->
    <div class="relative isolate px-6 pt-14 lg:px-8">
      <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80 float-animation">
        <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-30 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"></div>
      </div>
      
      <div class="mx-auto max-w-2xl py-28 sm:py-44 lg:py-52">
        <div class="js-home-hero text-center">
          <h1 class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-6xl lg:text-7xl text-balance">
            {siteConfig.name}
          </h1>
          <p class="mt-6 text-lg leading-8 text-gray-600 sm:text-xl text-balance">
            {siteConfig.tagline}
          </p>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
            <a href={getStartedPath} data-magnetic class="hig-button-primary px-5 py-2.5 text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600">
              Get started
            </a>
            <a href={siteConfig.repositoryUrl} data-magnetic class="hig-button-secondary px-5 py-2.5 text-sm">
              View on GitHub
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Documentation sections -->
    <div class="mx-auto max-w-7xl px-6 lg:px-8 pb-24">
      <div class="mx-auto max-w-2xl lg:text-center">
        <h2 class="text-base font-semibold leading-7 text-blue-600">Documentation</h2>
        <p class="mt-2 text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl text-balance">
          Everything you need to know
        </p>
        <p class="mt-6 text-lg leading-8 text-gray-600">
          Choose a section to learn more about our platform and how to get the most out of it.
        </p>
      </div>
      
      <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-4xl">
        <dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-2 lg:gap-y-16">
          {sortedDocs.map((doc) => (
            <div class="js-doc-card group hig-card relative pl-16 p-6">
              <dt class="text-base font-semibold leading-7 text-gray-900">
                <div class="absolute left-4 top-6 flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 text-white shadow-md transition-transform duration-200 group-hover:scale-105">
                  <DocIcon name={doc.data.icon} className="h-6 w-6 text-white" />
                </div>
                {doc.data.title}
              </dt>
              <dd class="mt-2 text-base leading-7 text-gray-600">
                {doc.data.description}
                <div class="mt-4">
                  <a 
                    href={getDocPath(doc)} 
                    class="inline-flex items-center text-sm font-semibold text-blue-600 hover:text-blue-500 transition-colors duration-200"
                  >
                    Learn more 
                    <ArrowRight className="ml-1 h-4 w-4" aria-hidden="true" />
                  </a>
                </div>
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-50 border-t border-gray-200">
      <div class="mx-auto max-w-7xl px-6 py-12 md:flex md:items-center md:justify-between lg:px-8">
        <div class="flex justify-center space-x-6 md:order-2">
          <a href={siteConfig.communityUrl} class="text-gray-400 hover:text-gray-500">
            <span class="sr-only">GitHub</span>
            <Code2 className="h-6 w-6" aria-hidden="true" />
          </a>
        </div>
        <div class="mt-8 md:order-1 md:mt-0">
          <p class="text-center text-xs leading-5 text-gray-500">
            Built with Astro • {siteConfig.footerText}
          </p>
        </div>
      </div>
    </footer>

    <script>
      import { gsap } from 'gsap';

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        gsap.from('.js-home-hero > *', {
          y: 22,
          opacity: 0,
          duration: 0.75,
          stagger: 0.12,
          ease: 'power2.out'
        });

        gsap.from('.js-doc-card', {
          y: 20,
          opacity: 0,
          duration: 0.65,
          stagger: 0.08,
          delay: 0.2,
          ease: 'power2.out'
        });

        const magneticButtons = Array.from(document.querySelectorAll<HTMLElement>('[data-magnetic]'));

        magneticButtons.forEach((button) => {
          const strength = 10;

          const reset = () => {
            gsap.to(button, {
              x: 0,
              y: 0,
              duration: 0.35,
              ease: 'power3.out'
            });
          };

          button.addEventListener('pointermove', (event: PointerEvent) => {
            const rect = button.getBoundingClientRect();
            const offsetX = ((event.clientX - rect.left) / rect.width - 0.5) * strength;
            const offsetY = ((event.clientY - rect.top) / rect.height - 0.5) * strength;

            gsap.to(button, {
              x: offsetX,
              y: offsetY,
              duration: 0.18,
              ease: 'power3.out'
            });
          });

          button.addEventListener('pointerleave', reset);
          button.addEventListener('blur', reset);
        });
      }
    </script>
  </body>
</html>
