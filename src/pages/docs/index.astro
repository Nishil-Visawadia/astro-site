---
// Keep /docs stable and redirect users to the canonical introduction page.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=/docs/introduction" />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href="/docs/introduction" />
    <title>Redirecting to introduction</title>
  </head>
  <body>
    <p>
      Redirecting to the docs introduction. If you are not redirected,
      <a href="/docs/introduction">open the introduction page</a>.
    </p>
  </body>
</html>
