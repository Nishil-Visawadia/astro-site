---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getDocSegments } from '../../lib/docs';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => {
    const segments = getDocSegments(entry);

    return {
      // [...slug] expects a slash-delimited string or undefined.
      params: { slug: segments.length === 0 ? undefined : segments.join('/') },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<DocsLayout title={entry.data.title} description={entry.data.description}>
  <div class="mb-8">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      {entry.data.title}
    </h1>
    <p class="mt-2 text-lg text-gray-600">
      {entry.data.description}
    </p>
  </div>

  <Content />
</DocsLayout>

